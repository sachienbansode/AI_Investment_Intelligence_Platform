# ── LLM Providers (set at least one) ────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Preferred provider order (comma-separated): anthropic,openai,gemini
LLM_PROVIDER_ORDER=anthropic,openai,gemini
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-pro

# ── Broker market-data APIs (optional; see docs/ACCOUNT_SETUP_GUIDE.md) ──
# Zerodha Kite Connect
KITE_API_KEY=
KITE_ACCESS_TOKEN=
# Angel One SmartAPI
SMARTAPI_KEY=
SMARTAPI_CLIENT_ID=
SMARTAPI_ACCESS_TOKEN=
# Upstox
UPSTOX_ACCESS_TOKEN=

# ── App ──────────────────────────────────────────────────────────
# SQLite (dev):     sqlite:///./broking_ai.db
# Postgres on AWS:  postgresql+psycopg2://USER:PASSWORD@your-rds-host.ap-south-1.rds.amazonaws.com:5432/broking_ai?sslmode=require
DATABASE_URL=sqlite:///./broking_ai.db
ENVIRONMENT=development

# Long random string; required in production.
# Admin user: run `python scripts/create_admin.py` once (interactive).
JWT_SECRET=dev-secret-change-in-production
SCORING_UNIVERSE=RELIANCE,TCS,HDFCBANK,INFY,ICICIBANK,ITC,SBIN,BHARTIARTL,LT,HINDUNILVR
DAILY_SCORING_HOUR=7
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Immutable audit trail location. In Docker/AWS point this at a mounted volume
# (the prod compose file sets /data/audit.log automatically).
AUDIT_LOG_PATH=audit.log

# Embedding model for the broker-research RAG store (used only if OPENAI_API_KEY
# is set; otherwise a deterministic local fallback embedding is used).
EMBEDDING_MODEL=text-embedding-3-small
